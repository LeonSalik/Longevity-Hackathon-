    "if not report_path.exists():\n",
    "    raise FileNotFoundError(f\"Report not found: {report_path.resolve()}\")\n",
    "\n",
    "print(f\"Processing: {report_path.name}  ({report_path.stat().st_size/1024:.1f} KB) ...\")\n",
